{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "filesystem",
  "description": "Filesystem access for the file manager",
  "windows": [
    "main"
  ],
  "permissions": [
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-stat",
    "fs:allow-read-dir",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$CACHE/**" },
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$PICTURE/**" },
        { "path": "$MUSIC/**" },
        { "path": "$VIDEO/**" }
      ],
      "deny": [
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.config/**" }
      ]
    }
  ]
}
